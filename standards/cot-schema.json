{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/open-cot/open-cot/standards/cot-schema.json",
  "title": "Open CoT trace",
  "description": "JSON Schema for chain-of-thought / reasoning traces in the open-cot format.",
  "type": "object",
  "required": ["version", "steps"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version (semver)."
    },
    "task_id": {
      "type": "string",
      "description": "Optional stable identifier for the task or prompt."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Domain-specific metadata (model, temperature, etc.)."
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["reasoning", "tool", "correction", "summary"],
            "description": "Semantic role of this step."
          },
          "content": {
            "type": "string",
            "description": "Step text or structured payload as string."
          },
          "refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional citations or tool call ids."
          }
        },
        "additionalProperties": true
      }
    },
    "final_answer": {
      "type": "string",
      "description": "Optional canonical final answer separate from reasoning."
    }
  },
  "additionalProperties": false
}
