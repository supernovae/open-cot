{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenCoT Multi-Agent Protocol v0.1",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "0.1"
      ]
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "agent_id",
          "role"
        ]
      }
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string"
          },
          "sender": {
            "type": "string"
          },
          "receiver": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": [
          "message_id",
          "sender",
          "receiver",
          "content"
        ]
      }
    },
    "shared_memory": {
      "type": "object"
    },
    "coordination_strategy": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "agents",
    "messages"
  ],
  "$id": "https://opencot.dev/schemas/rfc-0012-dataset-streaming.json",
  "x-opencot": {
    "rfc": "0012",
    "shortname": "dataset_streaming",
    "source_rfc": "rfcs/0012-dataset-streaming-format.md"
  }
}
